# Neon Postgres connection string
# Get this from your Neon dashboard → Connection Details → Connection string
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# OpenAI API key (also works with OpenRouter, Groq, etc. via LLM_BASE_URL)
OPENAI_API_KEY=sk-...

# LLM Configuration
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_FAST=gpt-4o-mini
LLM_MODEL_SMART=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small

# YouTube Data API key (for comment collection)
YOUTUBE_API_KEY=

# Content Niche (what audience the pipeline extracts insights for)
CONTENT_NICHE=software developers, tech workers, or people navigating AI's impact on technical careers
